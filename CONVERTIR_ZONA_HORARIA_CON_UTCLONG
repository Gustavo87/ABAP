CLASS zcl_experimentos DEFINITION
  PUBLIC
  FINAL
  CREATE PUBLIC .

  PUBLIC SECTION.
  interfaces if_oo_adt_classrun.
  PROTECTED SECTION.
  PRIVATE SECTION.
ENDCLASS.



CLASS zcl_experimentos IMPLEMENTATION.
  METHOD if_oo_adt_classrun~main.
    DATA: lv_time type utclong.
    DATA: lv_fecha type d, lv_hora type t.
    lv_time = utclong_add( val = utclong_current(  ) hours = -6 ).
    CONVERT UTCLONG lv_time
    TIME ZONE cl_abap_context_info=>get_user_time_zone(  )
    INTO DATE lv_fecha
    TIME lv_hora.

    out->write( |  { lv_fecha } { lv_hora } | ).
  ENDMETHOD.

ENDCLASS.
