CLASS zcl_experimentos DEFINITION
  PUBLIC
  FINAL
  CREATE PUBLIC .

  PUBLIC SECTION.
  interfaces if_oo_adt_classrun.
  PROTECTED SECTION.
  PRIVATE SECTION.
ENDCLASS.



CLASS zcl_experimentos IMPLEMENTATION.
  METHOD if_oo_adt_classrun~main.

        " Las funciones get_system_date y get_user_time_zone devuelven la hora del servidor en formato UTC, entonces para convertir a hora local de Nicaragua UTC-6
        " Podemos utilizar el siguiente código.
        DATA: lv_timestamp    TYPE timestamp,
              lv_date_system  TYPE d,
              lv_time_system  TYPE t,
              lv_tzone_src    TYPE string,
              lv_date_local   TYPE d,
              lv_time_local   TYPE t.

        " 1) Obtener fecha, hora y zona del sistema
        lv_date_system = cl_abap_context_info=>get_system_date( ).
        lv_time_system = cl_abap_context_info=>get_system_time( ).
        lv_tzone_src   = cl_abap_context_info=>get_user_time_zone( ).

        " 2) Obtener timestamp actual (UTC)
        GET TIME STAMP FIELD lv_timestamp.

        " 3) Convertir timestamp a hora de Nicaragua (UTC-6)
        CONVERT TIME STAMP lv_timestamp
                TIME ZONE 'UTC-6'
                INTO DATE lv_date_local
                     TIME lv_time_local.

        " 4) Mostrar resultados
        out->write( |--- DATOS DEL SISTEMA ---| ).
        out->write( |Fecha sistema : { lv_date_system }| ).
        out->write( |Hora sistema  : { lv_time_system }| ).
        out->write( |Zona sistema  : { lv_tzone_src }| ).

        out->write( | | ).

        out->write( |--- CONVERSIÓN A NICARAGUA ---| ).
        out->write( |Timestamp UTC : { lv_timestamp }| ).
        out->write( |Fecha Nicaragua: { lv_date_local }| ).
        out->write( |Hora Nicaragua : { lv_time_local }| ).
  ENDMETHOD.

ENDCLASS.
